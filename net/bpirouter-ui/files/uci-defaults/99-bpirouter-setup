#!/bin/sh

# 1. Move the native uhttpd backend to port 8081 to avoid conflicts
if [ -f /etc/config/uhttpd ]; then
    uci set uhttpd.main.listen_http='0.0.0.0:8081'
    uci set uhttpd.main.listen_https=''
    uci delete uhttpd.main.redirect_https 2>/dev/null
    uci commit uhttpd
fi

# 2. Seize default_server authority, remove native placeholder configurations
uci delete nginx._lan 2>/dev/null || true
uci delete nginx._redirect2ssl 2>/dev/null || true
uci commit nginx

# 3. Generate SSL certificates required for Nginx
/usr/bin/bpirouter-gen-cert

# 4. Deploy Nginx routing configuration (use symbolic links instead of cp, complying with OpenWrt specifications)
mkdir -p /etc/nginx/conf.d
ln -sf /usr/share/bpirouter/nginx/bpirouter.conf /etc/nginx/conf.d/
ln -sf /usr/share/bpirouter/nginx/bpirouter-locations.inc /etc/nginx/conf.d/
[ -f /etc/nginx/conf.d/default.conf ] && rm -f /etc/nginx/conf.d/default.conf

# 5. Register auto-start services (the system will automatically start them at the end of the boot process)
/etc/init.d/bpirouter-api enable 2>/dev/null
/etc/init.d/nginx enable 2>/dev/null

exit 0
